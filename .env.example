# Server-side key for the Vercel AI Gateway.
# Keep this out of browser-exposed VITE_* variables.
AI_GATEWAY_API_KEY=

# Optional: override the AI Gateway model. Defaults to google/gemini-3-flash
# consistently across the Vite dev proxy, Supabase function, and PHP proxy.
AI_GATEWAY_MODEL=

# Optional override for the browser-facing AI proxy.
# Defaults to ${VITE_SUPABASE_URL}/functions/v1/copilot when VITE_SUPABASE_URL is set.
VITE_COPILOT_API_URL=
