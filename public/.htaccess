# Hostinger / Apache SPA fallback for TanStack Router client-side routes.
# Without this, deep links like /treasury or /signal-desk return 403/404.

Options -MultiViews
RewriteEngine On
RewriteBase /

# Let the PHP copilot proxy own /api/* routes. Without this, the SPA fallback can
# rewrite /api/ask-finance to index.html before /api/.htaccess runs.
RewriteRule ^api(?:/|$) - [L]

# Server-side redirect for the legacy /treasury alias so old bookmarks never
# trigger the client-side redirect dance that can leave the home page stuck.
RewriteRule ^treasury/?$ / [R=301,L]

# Don't rewrite real files (assets, favicon, etc.)
# Note: the -d (directory) check is intentionally omitted so that the root
# path "/" is explicitly served via the SPA fallback below rather than relying
# on LiteSpeed's directory-index resolution, which can surface stale cached
# pages on Hostinger.
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Everything else (including the root "/") → index.html (SPA handles routing)
RewriteRule ^ index.html [L]

# Cache hashed assets aggressively, never cache index.html
<FilesMatch "\.(js|css|woff2?|png|jpg|jpeg|gif|svg|webp|ico)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
<FilesMatch "index\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>

# Basic security headers
Header set X-Content-Type-Options "nosniff"
Header set X-Frame-Options "SAMEORIGIN"
Header set Referrer-Policy "strict-origin-when-cross-origin"
